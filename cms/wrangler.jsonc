{
	"main": ".open-next/worker.js",
	"name": "probus-cms",
	"compatibility_date": "2025-11-01",
	"compatibility_flags": [
		"nodejs_compat"
	],
	"assets": {
		"directory": ".open-next/assets",
		"binding": "ASSETS"
	},
	"d1_databases": [
		{
			"binding": "D1",
			"database_id": "950b9dc5-b8a9-43ad-be3d-278c3ab95401",
			"database_name": "probus-cms"
		}
	],
	"r2_buckets": [
		{
			"binding": "R2",
			"bucket_name": "probus-media"
		}
	]
}