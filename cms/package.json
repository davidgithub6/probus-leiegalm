{
    "name": "probus-cms",
    "version": "1.0.0",
    "description": "Payload CMS backend for Probus LEIEGALM website",
    "license": "MIT",
    "type": "module",
    "scripts": {
        "build": "cross-env NODE_OPTIONS=\"--no-deprecation --max-old-space-size=8000\" next build",
        "deploy": "npm run deploy:database && npm run deploy:app",
        "deploy:app": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
        "deploy:database": "cross-env NODE_ENV=production PAYLOAD_SECRET=ignore payload migrate && wrangler d1 execute D1 --command 'PRAGMA optimize' --remote",
        "dev": "cross-env NODE_OPTIONS=--no-deprecation next dev",
        "devsafe": "rimraf .next && rimraf .open-next && cross-env NODE_OPTIONS=--no-deprecation next dev",
        "generate:importmap": "cross-env NODE_OPTIONS=--no-deprecation payload generate:importmap",
        "generate:types": "cross-env NODE_OPTIONS=--no-deprecation payload generate:types",
        "payload": "cross-env NODE_OPTIONS=--no-deprecation payload",
        "start": "cross-env NODE_OPTIONS=--no-deprecation next start"
    },
    "dependencies": {
        "@opennextjs/cloudflare": "^1.11.0",
        "@payloadcms/db-d1-sqlite": "3.77.0",
        "@payloadcms/next": "3.77.0",
        "@payloadcms/richtext-lexical": "3.77.0",
        "@payloadcms/storage-r2": "3.77.0",
        "@payloadcms/ui": "3.77.0",
        "cross-env": "^7.0.3",
        "dotenv": "16.4.7",
        "graphql": "^16.8.1",
        "next": "15.4.11",
        "payload": "3.77.0",
        "react": "19.2.1",
        "react-dom": "19.2.1"
    },
    "devDependencies": {
        "@types/node": "22.19.9",
        "@types/react": "19.2.9",
        "@types/react-dom": "19.2.3",
        "typescript": "5.7.3",
        "wrangler": "~4.61.1"
    },
    "engines": {
        "node": "^18.20.2 || >=20.9.0"
    }
}